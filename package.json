{
  "name": "meldui-tmp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "biome check src/",
    "lint:fix": "biome check --fix src/",
    "format": "biome format --write src/",
    "format:check": "biome format src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "agent:install": "cd src/agent && bun install",
    "agent:build": "cd src/agent && bun run build.ts",
    "tauri:build": "bun run agent:build && tauri build --bundles app",
    "tauri:build:dev": "bun run agent:build && tauri build --no-bundle",
    "tauri:dev": "bun run agent:build && tauri dev",
    "e2e:build-mock": "cd e2e/mock-sidecar && bun run build.ts",
    "e2e:test": "wdio run e2e/wdio.conf.ts",
    "e2e": "bun run e2e:build-mock && bun run tauri:build && bun run e2e:test",
    "version:bump": "bun run scripts/version-bump.ts",
    "version:check": "bun run scripts/version-check.ts",
    "knip": "knip",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.91.2",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-store": "^2.4.2",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.1",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.7.3",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.0.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@evilmartians/lefthook": "^2.1.4",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "@wdio/cli": "^9.26.0",
    "@wdio/local-runner": "^9.26.0",
    "@wdio/mocha-framework": "^9.26.0",
    "@wdio/spec-reporter": "^9.26.0",
    "jsdom": "^28.1.0",
    "knip": "^6.0.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "webdriverio": "^9.26.0"
  },
  "knip": {
    "ignore": [
      "src/bindings.ts",
      "src/agent/**",
      "e2e/**",
      "src/shared/ui/**",
      "src/shared/types/index.ts",
      "src/shared/lib/sync/types.ts",
      "src/shared/components/sections/collapsible-section.tsx"
    ],
    "ignoreDependencies": [
      "@tauri-apps/plugin-dialog",
      "@tauri-apps/plugin-shell",
      "@wdio/local-runner",
      "@wdio/mocha-framework",
      "@wdio/spec-reporter",
      "webdriverio"
    ],
    "ignoreExportsUsedInFile": true
  }
}
